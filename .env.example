APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
MCP_SERVER_URL=
FILAMENT_ADMIN_EMAIL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="support@pulse.digispace.pro"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eus3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=
MINIO_ENDPOINT=
FORWARD_MINIO_PORT=9005

VITE_APP_NAME="${APP_NAME}"

TURNSTILE_ACTIVE=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

TELESCOPE_RECORD_ALL=true

L5_SWAGGER_UI_DARK_MODE=true

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=DigiPulseBot
TELEGRAM_WEBHOOK_SECRET=

# Monitoring
INTERNET_CHECK_ENABLED=true
INTERNET_PROBE_URL=https://www.cloudflare.com
INTERNET_PROBE_TIMEOUT_SEC=5
MONITOR_RESULTS_CONSUMER_ENABLED=true
MONITOR_RESULTS_QUEUE=monitoring:results
MONITOR_RESULTS_CONSUMER_BLOCK_SECONDS=5
MONITOR_HEALTH_URL=http://digipulse-monitor:8080/health
MONITOR_HEALTH_TIMEOUT_SEC=5
SITE_LIMIT=3
