{
    "openapi": "3.0.0",
    "info": {
        "title": "DigiPulse API",
        "description": "API documentation for the DigiPulse monitoring system. **Authentication:** Use these endpoints to register, login, and manage user tokens.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost",
            "description": "Local Development Server"
        }
    ],
    "paths": {
        "/api/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Register a new user",
                "operationId": "58fe5a217ef88ae75e9b530a5e5817d1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "user": {
                                            "$ref": "#/components/schemas/UserSchema"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcd1234..."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    }
                ]
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login user",
                "description": "Authenticate a user and return a token",
                "operationId": "loginUser",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful login",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    }
                ]
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout user",
                "description": "Revoke the authenticated user's tokens",
                "operationId": "logoutUser",
                "responses": {
                    "200": {
                        "description": "Successful logout",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Successfully logged out"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/check-types": {
            "get": {
                "tags": [
                    "Check Types"
                ],
                "summary": "List available check types",
                "description": "Display a listing of available check types.",
                "operationId": "84421a098ff2c520c3c691114b6f9c54",
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/CheckTypeSchema"
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/sites": {
            "get": {
                "tags": [
                    "Sites"
                ],
                "summary": "List user sites",
                "description": "Display a listing of the user's sites.",
                "operationId": "a80e31c61764092a9710da892b4f6281",
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/SiteSchema"
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Sites"
                ],
                "summary": "Store a new site",
                "description": "Creates a new site for monitoring. You can optionally pass an array of checks to be configured for this site.",
                "operationId": "1c99621d9a5bfd1e1ba8c7e8b2859cb2",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/StoreSiteRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Site created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SiteSchema"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/sites/{site}": {
            "get": {
                "tags": [
                    "Sites"
                ],
                "summary": "Get site record",
                "description": "Display the specified site.",
                "operationId": "de9e22139a42ea7cd4944910230d17f3",
                "parameters": [
                    {
                        "name": "site",
                        "in": "path",
                        "description": "The site ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SiteSchema"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Site not found"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Sites"
                ],
                "summary": "Update existing site",
                "description": "Update the specified site in storage.",
                "operationId": "c3015a0e584490e7657e48f6080151a5",
                "parameters": [
                    {
                        "name": "site",
                        "in": "path",
                        "description": "The site ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateSiteRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Site updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SiteSchema"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Site not found"
                    },
                    "422": {
                        "description": "Validation failed"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Sites"
                ],
                "summary": "Delete site",
                "description": "Remove the specified site from storage.",
                "operationId": "b1c78bebaff88b90ddea188faf446ded",
                "parameters": [
                    {
                        "name": "site",
                        "in": "path",
                        "description": "The site ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Site deleted successfully"
                    },
                    "404": {
                        "description": "Site not found"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/sites/{site}/history": {
            "get": {
                "tags": [
                    "Sites"
                ],
                "summary": "Get aggregated check history for a site",
                "description": "Returns hourly aggregated stats (avg response time, uptime %) and a list of individual \"down\" incidents for the given ISO week. Defaults to the current week if no `week` param is provided. For past weeks (older than 7 days), data is served from the weekly archive.",
                "operationId": "3b0b3e7ba2b9fba26b264a12dcfd67ad",
                "parameters": [
                    {
                        "name": "site",
                        "in": "path",
                        "description": "The site ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    },
                    {
                        "name": "week",
                        "in": "query",
                        "description": "ISO-8601 week string (e.g. 2024-W15). Defaults to the current week.",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "2024-W15"
                        }
                    },
                    {
                        "name": "configuration_id",
                        "in": "query",
                        "description": "Filter results to a single check configuration.",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 3
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Aggregated history returned",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/SiteHistorySchema"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Site not found"
                    },
                    "422": {
                        "description": "Validation error (invalid week format)"
                    }
                },
                "security": [
                    {
                        "frontendKey": []
                    },
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "CheckTypeSchema": {
                "required": [
                    "id",
                    "name",
                    "slug",
                    "is_active"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "HTTP Status"
                    },
                    "slug": {
                        "type": "string",
                        "example": "http"
                    },
                    "description": {
                        "type": "string",
                        "example": "Verifies the website returns a 200 OK.",
                        "nullable": true
                    },
                    "icon": {
                        "type": "string",
                        "example": "heroicon-o-globe-alt",
                        "nullable": true
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "ConfigurationSchema": {
                "required": [
                    "id",
                    "is_active"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 10
                    },
                    "check_type": {
                        "$ref": "#/components/schemas/CheckTypeSchema"
                    },
                    "params": {
                        "type": "object",
                        "example": {
                            "keyword": "test"
                        },
                        "nullable": true
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "last_status": {
                        "type": "string",
                        "example": "up",
                        "nullable": true
                    },
                    "last_checked_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "HistoryIncident": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 123,
                        "nullable": true
                    },
                    "configuration_id": {
                        "type": "integer",
                        "example": 5
                    },
                    "status": {
                        "type": "string",
                        "example": "down"
                    },
                    "response_time_ms": {
                        "type": "integer",
                        "example": null,
                        "nullable": true
                    },
                    "error_message": {
                        "type": "string",
                        "example": "Connection timeout",
                        "nullable": true
                    },
                    "metadata": {
                        "type": "object",
                        "nullable": true
                    },
                    "checked_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-04-07T10:15:22"
                    }
                },
                "type": "object"
            },
            "HistoryStatBucket": {
                "properties": {
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2024-04-07T10:00:00+00:00"
                    },
                    "avg_response_time": {
                        "type": "number",
                        "format": "float",
                        "example": 142.5
                    },
                    "uptime_percentage": {
                        "type": "number",
                        "format": "float",
                        "example": 98.33
                    },
                    "count": {
                        "type": "integer",
                        "example": 60
                    }
                },
                "type": "object"
            },
            "SiteHistorySchema": {
                "properties": {
                    "stats": {
                        "description": "Hourly aggregated check data for graphing",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/HistoryStatBucket"
                        }
                    },
                    "incidents": {
                        "description": "Individual \"down\" events for incident markers on the chart",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/HistoryIncident"
                        }
                    }
                },
                "type": "object"
            },
            "SiteSchema": {
                "required": [
                    "id",
                    "name",
                    "url",
                    "update_interval",
                    "is_active",
                    "created_at",
                    "updated_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 5
                    },
                    "name": {
                        "type": "string",
                        "example": "Example.com"
                    },
                    "url": {
                        "type": "string",
                        "example": "https://example.com"
                    },
                    "update_interval": {
                        "type": "integer",
                        "example": 300
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "configurations": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ConfigurationSchema"
                        }
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2025-11-16T09:01:11.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2025-11-16T09:01:11.000000Z"
                    }
                },
                "type": "object"
            },
            "UserSchema": {
                "required": [
                    "id",
                    "name",
                    "email",
                    "first_name",
                    "last_name",
                    "created_at",
                    "updated_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 2
                    },
                    "name": {
                        "type": "string",
                        "example": "johndoug"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "johtdouj@gmail.pro"
                    },
                    "first_name": {
                        "type": "string",
                        "example": "John"
                    },
                    "last_name": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "email_verified_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2025-11-16T09:01:11.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2025-11-16T09:01:11.000000Z"
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "yurii@example.com"
                    },
                    "password": {
                        "type": "string",
                        "example": "StrongPass123!"
                    }
                },
                "type": "object"
            },
            "RegisterRequest": {
                "required": [
                    "name",
                    "email",
                    "first_name",
                    "last_name",
                    "password",
                    "password_confirmation"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "johndou"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "johndou@gmail.pro"
                    },
                    "first_name": {
                        "type": "string",
                        "example": "John"
                    },
                    "last_name": {
                        "type": "string",
                        "example": "Dou"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "StrongPass123!"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "StrongPass123!"
                    }
                },
                "type": "object"
            },
            "StoreSiteRequest": {
                "required": [
                    "name",
                    "url"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Example Site"
                    },
                    "url": {
                        "type": "string",
                        "format": "url",
                        "example": "https://example.com"
                    },
                    "update_interval": {
                        "description": "Interval in seconds",
                        "type": "integer",
                        "example": 300
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "checks": {
                        "type": "array",
                        "items": {
                            "properties": {
                                "check_type_id": {
                                    "type": "integer",
                                    "example": 1
                                },
                                "params": {
                                    "type": "object",
                                    "example": {
                                        "keyword": "test"
                                    },
                                    "nullable": true
                                }
                            },
                            "type": "object"
                        }
                    }
                },
                "type": "object"
            },
            "UpdateSiteRequest": {
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Example Site Updated"
                    },
                    "url": {
                        "type": "string",
                        "format": "url",
                        "example": "https://example-updated.com"
                    },
                    "update_interval": {
                        "description": "Interval in seconds",
                        "type": "integer",
                        "example": 300
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    },
                    "checks": {
                        "type": "array",
                        "items": {
                            "properties": {
                                "id": {
                                    "description": "Existing configuration ID to update, if provided",
                                    "type": "integer",
                                    "example": 1
                                },
                                "check_type_id": {
                                    "type": "integer",
                                    "example": 1
                                },
                                "params": {
                                    "type": "object",
                                    "example": {
                                        "keyword": "test"
                                    },
                                    "nullable": true
                                }
                            },
                            "type": "object"
                        }
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "frontendKey": {
                "type": "apiKey",
                "description": "Custom frontend key for API access",
                "name": "X-Frontend-Key",
                "in": "header"
            },
            "bearerAuth": {
                "type": "http",
                "description": "BearerAuth access token",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Check Types",
            "description": "Check Types"
        },
        {
            "name": "Sites",
            "description": "Sites"
        }
    ]
}